---
layout: layouts/base.njk
permalink: /b2b/
title: B2B
subtitle: Resilienz-Coaching für Unternehmen, Workshops & Vorträge
---
{% set p = pages.b2b %}
{% set cta = p.cta %}
<!-- Subpage Hero · 2-Spalter mit Sketch rechts -->
<section class="subpage-hero">
  <div class="container subpage-hero-grid">
    <div>
      <span class="eyebrow">{{ p.hero.eyebrow }}</span>
      <h1>{{ p.hero.headline }} <strong>{{ p.hero.headline_accent }}</strong></h1>
      <p class="lead">{{ p.hero.lead }}</p>
    </div>
    <div class="hero-sketch" aria-hidden="true">
      <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M 50 6 C 72 6 94 26 94 50 C 94 74 72 94 50 94 C 26 94 6 72 6 50 C 6 26 28 6 50 6 Z"/>
        <path d="M 50 14 C 68 14 84 30 84 50 C 84 70 68 84 50 84 C 32 84 16 68 16 50 C 16 32 32 14 50 14 Z"/>
        <path d="M 50 22 C 64 22 76 34 76 50 C 76 66 64 76 50 76 C 34 76 24 64 24 50 C 24 34 36 22 50 22 Z"/>
        <path d="M 50 30 C 60 30 68 40 68 50 C 68 60 60 68 50 68 C 40 68 32 60 32 50 C 32 40 40 30 50 30 Z"/>
        <path d="M 50 38 C 56 38 60 44 60 50 C 60 56 56 60 50 60 C 44 60 40 56 40 50 C 40 44 44 38 50 38 Z"/>
        <path d="M 50 45 C 53 45 55 47 55 50 C 55 53 53 55 50 55 C 47 55 45 53 45 50 C 45 47 47 45 50 45 Z"/>
        <circle cx="50" cy="50" r="1.5" fill="currentColor" stroke="none"/>
      </svg>
    </div>
  </div>
</section>

<!-- Methode -->
<section class="factors">
  <div class="container">
    <div class="factors-head">
      <span class="eyebrow">{{ p.method.eyebrow }}</span>
      <h2>{{ p.method.headline }} <strong>{{ p.method.headline_accent }}</strong></h2>
      <p style="opacity:.78;margin-top:1rem;max-width:54ch">{{ p.method.lead }}</p>
    </div>
    <div class="factor-grid">
      {% for item in p.method.items %}
      <div class="factor"><span class="factor-num">{{ item.num }}</span><h3>{{ item.title }}</h3><p>{{ item.text }}</p></div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Image break -->
<section class="image-section">
  <div class="container">
    <img src="{{ p.image_break.image }}" alt="{{ p.image_break.alt }}" style="display:block;width:100%;height:auto;border-radius:4px">
  </div>
</section>

<!-- Angebot -->
<section class="services">
  <div class="container">
    <div class="services-head">
      <span class="eyebrow">{{ p.services.eyebrow }}</span>
      <h2>{{ p.services.headline }} <strong>{{ p.services.headline_accent }}</strong></h2>
      <p class="lead">{{ p.services.lead }}</p>
    </div>
    <div class="service-grid">
      {% for s in p.services.items %}
      <article class="service service-teaser">
        <span class="service-num">{{ s.num }}</span>
        <h3>{{ s.title }}</h3>
        <p class="service-lead">{{ s.text }}</p>
        <a href="#" data-open-modal="{{ s.cta_modal }}" class="about-teaser-cta">Anfragen <span>→</span></a>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Themen -->
<section class="topics">
  <div class="container">
    <span class="topics-eyebrow">{{ p.topics.eyebrow }}</span>
    <div class="topics-grid">
      {% for tag in p.topics.tags %}<span class="tag">{{ tag }}</span>{% endfor %}
    </div>
  </div>
</section>

{% include "partials/cta-block.njk" %}
