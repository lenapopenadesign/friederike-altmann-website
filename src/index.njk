---
layout: layouts/base.njk
permalink: /
subtitle: Systemisches Coaching für Resilienz & Mentale Gesundheit
---
{% set p = pages.index %}
<!-- Hero -->
<section class="hero">
  <div class="container hero-grid">
    <div>
      <span class="eyebrow">{{ p.hero.eyebrow }}</span>
      <h1>{{ p.hero.headline }} <strong>{{ p.hero.headline_accent }}</strong></h1>
      <p class="hero-sub">{{ p.hero.lead }}</p>
      <div class="hero-cta-row">
        <a href="#" data-open-modal="allgemein" class="btn btn-primary">{{ site.cta_label }} <span class="arrow">→</span></a>
        <a href="{{ p.hero.cta_secondary_url }}" class="btn btn-ghost">{{ p.hero.cta_secondary }}</a>
      </div>
    </div>
    <div class="hero-visual">
      <img src="{{ p.hero.image }}" alt="{{ site.name }} · {{ p.hero.image_credit_label }}" onerror="this.style.display='none'">
      <a class="photo-credit" href="{{ p.hero.image_credit_url }}" target="_blank" rel="noopener">{{ p.hero.image_credit_label }}</a>
    </div>
  </div>
</section>

<!-- Topics -->
<section class="topics">
  <div class="container">
    <span class="topics-eyebrow">{{ topics.eyebrow }}</span>
    <div class="topics-grid">
      {% for tag in topics.tags %}<span class="tag">{{ tag }}</span>{% endfor %}
    </div>
  </div>
</section>

<!-- Methode-Teaser -->
<section class="methode-teaser" id="methode">
  <div class="container methode-teaser-grid">
    <div>
      <span class="eyebrow">{{ p.methode_teaser.eyebrow }}</span>
      <h2>{{ p.methode_teaser.headline }} <strong>{{ p.methode_teaser.headline_accent }}</strong></h2>
      <p>{{ p.methode_teaser.lead }}</p>
      <a href="{{ p.methode_teaser.cta_url }}" class="about-teaser-cta">{{ p.methode_teaser.cta_label }} <span>→</span></a>
    </div>
    <div class="methode-tokens">
      {% for token in p.methode_teaser.tokens %}
      <div class="method-token">
        <span class="method-token-num">{{ token.num }}</span>
        <div class="method-token-content">
          <h4>{{ token.title }}</h4>
          <p>{{ token.text }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Angebot-Teaser -->
<section class="services" id="services">
  <div class="container">
    <div class="services-head">
      <span class="eyebrow">{{ p.services_teaser.eyebrow }}</span>
      <h2>{{ p.services_teaser.headline }} <strong>{{ p.services_teaser.headline_accent }}</strong></h2>
      <p class="lead">{{ p.services_teaser.lead }}</p>
    </div>
    <div class="service-grid">
      {% for item in p.services_teaser.items %}
      <article class="service service-teaser">
        <span class="service-num">{{ item.num }}</span>
        <h3>{{ item.title }}</h3>
        <p class="service-lead">{{ item.text }}</p>
        <a href="{{ item.url }}" class="about-teaser-cta">Mehr erfahren <span>→</span></a>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Image break · Gruppen-Atmosphäre (auf Mobile ausgeblendet) -->
<section class="image-section mobile-hide">
  <div class="container">
    <img src="{{ p.image_break_1.image }}" alt="{{ p.image_break_1.alt }}" style="display:block;width:100%;height:auto;border-radius:4px">
  </div>
</section>

<!-- Über mich-Teaser -->
<section class="about" id="about">
  <div class="container about-grid">
    <div class="about-visual">
      <img src="{{ p.about_teaser.image }}" alt="{{ site.name }} · Portrait · {{ p.about_teaser.image_credit_label }}" onerror="this.parentElement.querySelector('.about-visual-label').style.display='inline-block';this.style.display='none'">
      <span class="about-visual-label" style="display:none">Portrait · Business-Shooting</span>
      <a class="photo-credit" href="{{ p.about_teaser.image_credit_url }}" target="_blank" rel="noopener">{{ p.about_teaser.image_credit_label }}</a>
    </div>
    <div>
      <span class="eyebrow">{{ p.about_teaser.eyebrow }}</span>
      <h2>{{ p.about_teaser.headline }} <strong>{{ p.about_teaser.headline_accent }}</strong></h2>
      <span class="rule"></span>
      <p>{{ p.about_teaser.paragraph_1 }}</p>
      <p style="margin-top:1.1rem;font-size:.94rem;opacity:.75">{{ p.about_teaser.paragraph_2 }}</p>
      <a href="{{ p.about_teaser.cta_url }}" class="about-teaser-cta">{{ p.about_teaser.cta_label }} <span>→</span></a>
    </div>
  </div>
</section>

<!-- Stimmen -->
<section class="testimonials" id="testimonials">
  <div class="container">
    <div class="testimonials-head">
      <div class="testimonials-head-text">
        <span class="eyebrow">{{ p.testimonials_section.eyebrow }}</span>
        <h2>{{ p.testimonials_section.headline }} <strong>{{ p.testimonials_section.headline_accent }}</strong></h2>
      </div>
      <span class="testimonial-counter" aria-hidden="true" hidden>1 / {{ testimonials.items | length }}</span>
    </div>
    <div class="testimonial-slider-wrap">
      <div class="testimonial-grid">
        {% for t in testimonials.items %}
        <article class="testimonial">
          <span class="testimonial-mark">&ldquo;</span>
          <p>{{ t.quote }}</p>
          <div class="testimonial-meta">
            <span class="testimonial-name">{{ t.name }}</span>
            <span class="testimonial-role">{{ t.role }}</span>
          </div>
        </article>
        {% endfor %}
      </div>
      <button class="testimonial-nav-btn prev" type="button" aria-label="Vorheriges Zitat" hidden>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="testimonial-nav-btn next" type="button" aria-label="Nächstes Zitat" hidden>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</section>

<!-- Image break · Praxis-Raum -->
<section class="image-section">
  <div class="container">
    <img src="{{ p.image_break_2.image }}" alt="{{ p.image_break_2.alt }}" style="display:block;width:100%;height:540px;object-fit:cover;border-radius:4px">
  </div>
</section>

<!-- Ablauf -->
<section class="process" id="process">
  <div class="container">
    <div class="process-head">
      <span class="eyebrow">{{ p.process.eyebrow }}</span>
      <h2>{{ p.process.headline }} <strong>{{ p.process.headline_accent }}</strong></h2>
      <p style="opacity:.8;margin-top:.8rem">{{ p.process.lead }}</p>
    </div>
    <div class="steps">
      {% for step in p.process.steps %}
      <div class="step">
        <span class="step-num">{{ step.num }}</span>
        <h3>{{ step.title }}</h3>
        <p>{{ step.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Zitat -->
<section class="quote">
  <div class="container quote-wrap">
    <blockquote>&ldquo;{{ p.quote.text }}&rdquo;</blockquote>
    <div class="cite">{{ p.quote.author }}</div>
  </div>
</section>

<!-- FAQ -->
<section class="faq" id="faq">
  <div class="container faq-grid">
    <div>
      <span class="eyebrow">{{ p.faq_section.eyebrow }}</span>
      <h2>{{ p.faq_section.headline }} <strong>{{ p.faq_section.headline_accent }}</strong></h2>
      <p class="faq-lead">{{ p.faq_section.lead }}</p>
    </div>
    <div class="faq-items">
      {% for item in faq.items %}
      <details class="faq-item">
        <summary>{{ item.question }}</summary>
        <p>{{ item.answer }}</p>
      </details>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Kontakt -->
<section class="cta" id="contact">
  <div class="container cta-grid">
    <div>
      <span class="eyebrow on-dark">{{ p.contact.eyebrow }}</span>
      <h2>{{ p.contact.headline }} <strong>{{ p.contact.headline_accent }}</strong></h2>
      <p>{{ p.contact.text }}</p>
      <a href="#" data-open-modal="allgemein" class="btn btn-primary" style="margin-top:2rem">{{ site.cta_label }} <span class="arrow">→</span></a>
    </div>
    <div class="cta-card">
      <dl>
        <dt>E-Mail</dt><dd>{{ site.contact.email }}</dd>
        <dt>Telefon</dt><dd>{{ site.contact.phone }}</dd>
        <dt>Website</dt><dd>{{ site.contact.website }}</dd>
        <dt>Social</dt><dd>{{ site.contact.social }}</dd>
      </dl>
    </div>
  </div>
</section>
