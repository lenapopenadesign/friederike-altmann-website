---
layout: layouts/base.njk
permalink: /
subtitle: Systemisches Coaching für Resilienz & Mentale Gesundheit
hero:
  eyebrow: "Systemisches Coaching · München & online"
  headline: "Entspannt"
  headline_accent: "erfolgreich."
  lead: "Veränderung muss sich nicht schwer anfühlen. Ich begleite dich — beruflich wie privat — bis du deinen nächsten Schritt klar vor dir siehst."
  cta_secondary: "Mehr über das Angebot"
  cta_secondary_url: "/angebot/"
  image: "/assets/friederike-hero.jpg"
  image_credit_url: "https://mirjamhagen.com/"
  image_credit_label: "© Mirjam Hagen"
methode_teaser:
  eyebrow: "Methode"
  headline: "Wissenschaftlich fundiert."
  headline_accent: "Systemisch gedacht."
  lead: "Mein Ansatz steht auf zwei Säulen: systemisch-lösungsorientiertes Coaching und Resilienzforschung. Wir schauen nicht nur auf dich, sondern auf das ganze Bild — Beziehungen, Kontexte, Geschichte."
  cta_label: "Mehr zur Methode"
  cta_url: "/methode/"
  tokens:
    - num: "01"
      title: "Systemisch denken"
      text: "Niemand steht allein im Raum. Wir nehmen das ganze Umfeld in den Blick."
    - num: "02"
      title: "Lösungsorientiert arbeiten"
      text: "Davon aus denken, wo Stärke schon liegt — nicht das Problem zergliedern."
    - num: "03"
      title: "Resilienz aufbauen"
      text: "Sechs Faktoren, die trainierbar sind — als persönlicher Methodenkoffer."
services_teaser:
  eyebrow: "Angebot"
  headline: "Drei Formate,"
  headline_accent: "ein Ansatz."
  lead: "Alle Formate beginnen mit einem kostenlosen 15-Minuten-Gespräch. Danach entscheiden wir gemeinsam, ob und wie wir weitermachen."
  items:
    - num: "Format 01"
      title: "Das Einzel"
      text: "Eine Stunde, die nur dir gehört — und dich beruflich wie privat weiterbringt."
      url: "/angebot/#einzel"
    - num: "Format 02"
      title: "Der Prozess"
      text: "Ein geführter Prozess — so lange, bis echte Veränderung spürbar ist."
      url: "/angebot/#prozess"
    - num: "Format 03"
      title: "Die Gruppe"
      text: "Gemeinsam wachsen — durch Austausch, Reflexion und persönliche Weiterentwicklung."
      url: "/angebot/#gruppe"
about_teaser:
  eyebrow: "Über mich"
  headline: "Ich schaue auf das große Ganze —"
  headline_accent: "weil Leichtigkeit kein Zufall ist."
  paragraph_1: "Ich arbeite systemisch, wissenschaftlich fundiert und ganz auf dich ausgerichtet. Viele meiner Klient:innen kommen zu mir, wenn der Alltag zu schwer geworden ist — überfordert, im Dauerstress, ohne klaren Ausweg. Gemeinsam schauen wir nicht nur auf dich allein — sondern auch auf dein Umfeld: deine Beziehungen, dein Team, deine Geschichte. Ich stelle Fragen, du findest deine Antworten. Ich bringe wissenschaftlich fundierte Methoden mit, du entscheidest, was passt. Und zusammen gestalten wir deinen nächsten Schritt — hin zu mehr Leichtigkeit in deinem Leben."
  paragraph_2: "Ausbildung als Resilienz- und Systemische Coach, M. Sc. von der TU Berlin, 10+ Jahre Erfahrung in verschiedenen globalen Unternehmen u. a. als Sustainability Managerin, Mama einer kleinen Tochter. Ich arbeite in München und online."
  cta_label: "Meine ganze Geschichte"
  cta_url: "/meine-geschichte/"
  image: "/assets/friederike-about.png"
testimonials_section:
  eyebrow: "Stimmen"
  headline: "Was Klient:innen"
  headline_accent: "mitgenommen haben."
process:
  eyebrow: "Ablauf"
  headline: "So arbeiten wir"
  headline_accent: "zusammen."
  lead: "Ein klarer, zugleich offener Rahmen — damit der Inhalt Raum bekommt."
  steps:
    - num: "Schritt 01"
      title: "Kennenlernen"
      text: "15 Minuten online. Unverbindlich, offen, transparent und ohne Druck."
    - num: "Schritt 02"
      title: "Auftragsklärung"
      text: "In der ersten Sitzung (und kurz am Anfang jeder weiteren Sitzung) schärfen wir, worum es wirklich geht."
    - num: "Schritt 03"
      title: "Arbeitsphase"
      text: "Wir betrachten Muster, Ressourcen, Systeme. Gute Fragen, fundierte Methoden, keine Floskeln."
    - num: "Schritt 04"
      title: "Abschluss"
      text: "Wir sichern, was sich verändert hat — und definieren deine(n) nächsten Schritt(e)."
quote:
  text: "Problem talk creates problems and solution talk creates solutions."
  author: "Steve de Shazer · Erfinder der lösungsorientierten Kurztherapie"
faq_section:
  eyebrow: "FAQ"
  headline: "Was du"
  headline_accent: "vorher wissen möchtest."
  lead: "Hier die häufigsten Fragen — wenn deine nicht dabei ist, schreib mir einfach."
contact:
  eyebrow: "Kontakt"
  headline: "Ich freue mich"
  headline_accent: "von Dir zu hören!"
  text: "Schreib mir gerne hier über das Kontaktformular oder per Mail, wenn Du ein Coaching buchen möchtest oder Fragen dazu hast."
---
<!-- Hero -->
<section class="hero">
  <div class="container hero-grid">
    <div>
      <span class="eyebrow">{{ hero.eyebrow }}</span>
      <h1>{{ hero.headline }} <strong>{{ hero.headline_accent }}</strong></h1>
      <p class="hero-sub">{{ hero.lead }}</p>
      <div class="hero-cta-row">
        <a href="#" data-open-modal="allgemein" class="btn btn-primary">{{ site.cta_label }} <span class="arrow">→</span></a>
        <a href="{{ hero.cta_secondary_url }}" class="btn btn-ghost">{{ hero.cta_secondary }}</a>
      </div>
    </div>
    <div class="hero-visual">
      <img src="{{ hero.image }}" alt="{{ site.name }} · {{ hero.image_credit_label }}" onerror="this.style.display='none'">
      <a class="photo-credit" href="{{ hero.image_credit_url }}" target="_blank" rel="noopener">{{ hero.image_credit_label }}</a>
    </div>
  </div>
</section>

<!-- Topics -->
<section class="topics">
  <div class="container">
    <span class="topics-eyebrow">{{ topics.eyebrow }}</span>
    <div class="topics-grid">
      {% for tag in topics.tags %}<span class="tag">{{ tag }}</span>{% endfor %}
    </div>
  </div>
</section>

<!-- Methode-Teaser -->
<section class="methode-teaser" id="methode">
  <div class="container methode-teaser-grid">
    <div>
      <span class="eyebrow">{{ methode_teaser.eyebrow }}</span>
      <h2>{{ methode_teaser.headline }} <strong>{{ methode_teaser.headline_accent }}</strong></h2>
      <p>{{ methode_teaser.lead }}</p>
      <a href="{{ methode_teaser.cta_url }}" class="about-teaser-cta">{{ methode_teaser.cta_label }} <span>→</span></a>
    </div>
    <div class="methode-tokens">
      {% for token in methode_teaser.tokens %}
      <div class="method-token">
        <span class="method-token-num">{{ token.num }}</span>
        <div class="method-token-content">
          <h4>{{ token.title }}</h4>
          <p>{{ token.text }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Angebot-Teaser -->
<section class="services" id="services">
  <div class="container">
    <div class="services-head">
      <span class="eyebrow">{{ services_teaser.eyebrow }}</span>
      <h2>{{ services_teaser.headline }} <strong>{{ services_teaser.headline_accent }}</strong></h2>
      <p class="lead">{{ services_teaser.lead }}</p>
    </div>
    <div class="service-grid">
      {% for item in services_teaser.items %}
      <article class="service service-teaser">
        <span class="service-num">{{ item.num }}</span>
        <h3>{{ item.title }}</h3>
        <p class="service-lead">{{ item.text }}</p>
        <a href="{{ item.url }}" class="about-teaser-cta">Mehr erfahren <span>→</span></a>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Image break · Gruppen-Atmosphäre (auf Mobile ausgeblendet) -->
<section class="image-section mobile-hide">
  <div class="container">
    <img src="/assets/group-table.jpg" alt="Gruppen-Coaching · Atmosphäre am Tisch" style="display:block;width:100%;height:auto;border-radius:4px">
  </div>
</section>

<!-- Über mich-Teaser -->
<section class="about" id="about">
  <div class="container about-grid">
    <div class="about-visual">
      <img src="{{ about_teaser.image }}" alt="{{ site.name }} · Portrait · © Mirjam Hagen" onerror="this.parentElement.querySelector('.about-visual-label').style.display='inline-block';this.style.display='none'">
      <span class="about-visual-label" style="display:none">Portrait · Business-Shooting</span>
      <a class="photo-credit" href="https://mirjamhagen.com/" target="_blank" rel="noopener">© Mirjam Hagen</a>
    </div>
    <div>
      <span class="eyebrow">{{ about_teaser.eyebrow }}</span>
      <h2>{{ about_teaser.headline }} <strong>{{ about_teaser.headline_accent }}</strong></h2>
      <span class="rule"></span>
      <p>{{ about_teaser.paragraph_1 }}</p>
      <p style="margin-top:1.1rem;font-size:.94rem;opacity:.75">{{ about_teaser.paragraph_2 }}</p>
      <a href="{{ about_teaser.cta_url }}" class="about-teaser-cta">{{ about_teaser.cta_label }} <span>→</span></a>
    </div>
  </div>
</section>

<!-- Stimmen -->
<section class="testimonials" id="testimonials">
  <div class="container">
    <div class="testimonials-head">
      <div class="testimonials-head-text">
        <span class="eyebrow">{{ testimonials_section.eyebrow }}</span>
        <h2>{{ testimonials_section.headline }} <strong>{{ testimonials_section.headline_accent }}</strong></h2>
      </div>
      <span class="testimonial-counter" aria-hidden="true" hidden>1 / {{ testimonials.items | length }}</span>
    </div>
    <div class="testimonial-slider-wrap">
      <div class="testimonial-grid">
        {% for t in testimonials.items %}
        <article class="testimonial">
          <span class="testimonial-mark">&ldquo;</span>
          <p>{{ t.quote }}</p>
          <div class="testimonial-meta">
            <span class="testimonial-name">{{ t.name }}</span>
            <span class="testimonial-role">{{ t.role }}</span>
          </div>
        </article>
        {% endfor %}
      </div>
      <button class="testimonial-nav-btn prev" type="button" aria-label="Vorheriges Zitat" hidden>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="testimonial-nav-btn next" type="button" aria-label="Nächstes Zitat" hidden>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</section>

<!-- Image break · Praxis-Raum -->
<section class="image-section">
  <div class="container">
    <img src="/assets/room-window.jpg" alt="Atmosphäre · Fenster mit Eukalyptus" style="display:block;width:100%;height:540px;object-fit:cover;border-radius:4px">
  </div>
</section>

<!-- Ablauf -->
<section class="process" id="process">
  <div class="container">
    <div class="process-head">
      <span class="eyebrow">{{ process.eyebrow }}</span>
      <h2>{{ process.headline }} <strong>{{ process.headline_accent }}</strong></h2>
      <p style="opacity:.8;margin-top:.8rem">{{ process.lead }}</p>
    </div>
    <div class="steps">
      {% for step in process.steps %}
      <div class="step">
        <span class="step-num">{{ step.num }}</span>
        <h3>{{ step.title }}</h3>
        <p>{{ step.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Zitat -->
<section class="quote">
  <div class="container quote-wrap">
    <blockquote>&ldquo;{{ quote.text }}&rdquo;</blockquote>
    <div class="cite">{{ quote.author }}</div>
  </div>
</section>

<!-- FAQ -->
<section class="faq" id="faq">
  <div class="container faq-grid">
    <div>
      <span class="eyebrow">{{ faq_section.eyebrow }}</span>
      <h2>{{ faq_section.headline }} <strong>{{ faq_section.headline_accent }}</strong></h2>
      <p class="faq-lead">{{ faq_section.lead }}</p>
    </div>
    <div class="faq-items">
      {% for item in faq.items %}
      <details class="faq-item">
        <summary>{{ item.question }}</summary>
        <p>{{ item.answer }}</p>
      </details>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Kontakt -->
<section class="cta" id="contact">
  <div class="container cta-grid">
    <div>
      <span class="eyebrow on-dark">{{ contact.eyebrow }}</span>
      <h2>{{ contact.headline }} <strong>{{ contact.headline_accent }}</strong></h2>
      <p>{{ contact.text }}</p>
      <a href="#" data-open-modal="allgemein" class="btn btn-primary" style="margin-top:2rem">{{ site.cta_label }} <span class="arrow">→</span></a>
    </div>
    <div class="cta-card">
      <dl>
        <dt>E-Mail</dt><dd>{{ site.contact.email }}</dd>
        <dt>Telefon</dt><dd>{{ site.contact.phone }}</dd>
        <dt>Website</dt><dd>{{ site.contact.website }}</dd>
        <dt>Social</dt><dd>{{ site.contact.social }}</dd>
      </dl>
    </div>
  </div>
</section>
