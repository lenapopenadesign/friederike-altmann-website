---
layout: layouts/base.njk
permalink: /methode/
title: Methode
subtitle: Systemisches & lösungsorientiertes Coaching
---
{% set p = pages.methode %}
<!-- Subpage Hero -->
<section class="subpage-hero">
  <div class="container">
    <span class="eyebrow">{{ p.hero.eyebrow }}</span>
    <h1>{{ p.hero.headline }} <strong>{{ p.hero.headline_accent }}</strong></h1>
    <p class="lead">{{ p.hero.lead }}</p>
  </div>
</section>

<!-- Systemisch denken -->
<section class="prose">
  <div class="container">
    <span class="eyebrow">{{ p.section_systemisch.eyebrow }}</span>
    <h2>{{ p.section_systemisch.headline }} <strong>{{ p.section_systemisch.headline_accent }}</strong></h2>
    {% for para in p.section_systemisch.paragraphs %}<p>{{ para | safe }}</p>{% endfor %}
  </div>
</section>

<!-- Pull-Quote -->
<section class="pull-quote">
  <div class="pull-quote-wrap">
    <span class="pull-quote-mark">&ldquo;</span>
    <p class="pull-quote-text">{{ p.pull_quote.text }}</p>
    <div class="pull-quote-cite">{{ p.pull_quote.cite }}</div>
  </div>
</section>

<!-- Lösungsorientiert -->
<section class="prose on-flieder-soft">
  <div class="container">
    <span class="eyebrow">{{ p.section_loesungsorientiert.eyebrow }}</span>
    <h2>{{ p.section_loesungsorientiert.headline }} <strong>{{ p.section_loesungsorientiert.headline_accent }}</strong></h2>
    {% for para in p.section_loesungsorientiert.paragraphs %}<p>{{ para | safe }}</p>{% endfor %}
  </div>
</section>

<!-- 6 Resilienz-Faktoren -->
<section class="factors">
  <div class="container">
    <div class="factors-head">
      <span class="eyebrow">{{ p.factors.eyebrow }}</span>
      <h2>{{ p.factors.headline }} <strong>{{ p.factors.headline_accent }}</strong></h2>
      <p style="opacity:.78;margin-top:1rem;max-width:54ch">{{ p.factors.lead }}</p>
    </div>
    <div class="factor-grid">
      {% for f in p.factors.items %}
      <div class="factor"><span class="factor-num">{{ f.num }}</span><h3>{{ f.title }}</h3><p>{{ f.text }}</p></div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Resilienz-Profil & Methodenkoffer -->
<section class="prose on-flieder">
  <div class="container">
    <span class="eyebrow">{{ p.section_profil.eyebrow }}</span>
    <h2>{{ p.section_profil.headline }} <strong>{{ p.section_profil.headline_accent }}</strong></h2>
    {% for para in p.section_profil.paragraphs %}<p>{{ para | safe }}</p>{% endfor %}
  </div>
</section>

<!-- Wissenschaftlich fundiert -->
<section class="prose">
  <div class="container">
    <span class="eyebrow">{{ p.section_science.eyebrow }}</span>
    <h2>{{ p.section_science.headline }} <strong>{{ p.section_science.headline_accent }}</strong></h2>
    {% for para in p.section_science.paragraphs %}<p>{{ para | safe }}</p>{% endfor %}
  </div>
</section>

<!-- Compare: Was du nicht bekommst / Was du bekommst -->
<section class="compare">
  <div class="container">
    <div class="compare-grid">
      <div class="compare-card minus">
        <span class="compare-label">{{ p.compare.minus.label }}</span>
        <h3>{{ p.compare.minus.headline }}</h3>
        <ul>
          {% for item in p.compare.minus.items %}<li>{{ item }}</li>{% endfor %}
        </ul>
      </div>
      <div class="compare-card plus">
        <span class="compare-label">{{ p.compare.plus.label }}</span>
        <h3>{{ p.compare.plus.headline }}</h3>
        <ul>
          {% for item in p.compare.plus.items %}<li>{{ item }}</li>{% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- CTA-Block -->
{% include "partials/cta-block.njk" %}
