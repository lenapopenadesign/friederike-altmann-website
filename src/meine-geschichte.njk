---
layout: layouts/base.njk
permalink: /meine-geschichte/
title: Über mich
subtitle: Meine Geschichte
---
{% set p = pages.meine_geschichte %}
{% set cta = p.cta %}
<!-- Subpage Hero -->
<section class="subpage-hero">
  <div class="container subpage-hero-grid">
    <div>
      <span class="eyebrow">{{ p.hero.eyebrow }}</span>
      <h1>{{ p.hero.headline }} <strong>{{ p.hero.headline_accent }}</strong></h1>
      <p class="lead">{{ p.hero.lead }}</p>
    </div>
    <div class="subpage-portrait-wrap">
      <div class="subpage-portrait">
        <img src="{{ p.hero.image }}" alt="{{ site.name }} · Portrait · {{ p.hero.image_credit_label }}">
      </div>
      <a class="photo-credit-below" href="{{ p.hero.image_credit_url }}" target="_blank" rel="noopener">{{ p.hero.image_credit_label }}</a>
    </div>
  </div>
</section>

<!-- Wo ich herkomme -->
<section class="story">
  <div class="container story-grid">
    <div>
      <span class="eyebrow">{{ p.section_herkunft.eyebrow }}</span>
      <h2>{{ p.section_herkunft.headline }} <strong>{{ p.section_herkunft.headline_accent }}</strong></h2>
    </div>
    <div>
      {% for para in p.section_herkunft.paragraphs %}<p>{{ para | safe }}</p>{% endfor %}
    </div>
  </div>
</section>

<!-- Der Wendepunkt -->
<section class="story on-sand">
  <div class="container story-grid">
    <div>
      <span class="eyebrow">{{ p.section_wendepunkt.eyebrow }}</span>
      <h2>{{ p.section_wendepunkt.headline }} <strong>{{ p.section_wendepunkt.headline_accent }}</strong></h2>
    </div>
    <div>
      {% for para in p.section_wendepunkt.paragraphs %}<p>{{ para | safe }}</p>{% endfor %}
    </div>
  </div>
</section>

<!-- Pull-Quote -->
<section class="pull-quote">
  <div class="pull-quote-wrap">
    <span class="pull-quote-mark">&ldquo;</span>
    <p class="pull-quote-text">{{ p.pull_quote.text }}</p>
    <div class="pull-quote-cite">{{ site.name }}</div>
  </div>
</section>

<!-- Was ich mitgenommen habe · mit Sessel-Foto -->
<section class="story has-image">
  <div class="container story-image-grid">
    <div class="story-img">
      <img src="{{ p.section_ueberzeugungen.image }}" alt="{{ p.section_ueberzeugungen.image_alt }}">
    </div>
    <div>
      <span class="eyebrow">{{ p.section_ueberzeugungen.eyebrow }}</span>
      <h2>{{ p.section_ueberzeugungen.headline }} <strong>{{ p.section_ueberzeugungen.headline_accent }}</strong></h2>
      {% for c in p.section_ueberzeugungen.convictions %}
      <p><strong>{{ c.bold }}</strong> {{ c.text }}</p>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Heute -->
<section class="story on-flieder">
  <div class="container story-grid">
    <div>
      <span class="eyebrow">{{ p.section_heute.eyebrow }}</span>
      <h2>{{ p.section_heute.headline }} <strong>{{ p.section_heute.headline_accent }}</strong></h2>
    </div>
    <div>
      <p>{{ p.section_heute.paragraph_1 }}</p>
      <p>{{ p.section_heute.paragraph_2_html | safe }}</p>
      <p>{{ p.section_heute.paragraph_3 }}</p>
    </div>
  </div>
</section>

{% include "partials/cta-block.njk" %}
